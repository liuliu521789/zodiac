.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 40rpx 30rpx 120rpx;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.3);
  margin-bottom: 12rpx;
}

.date {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

.summary-card {
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  backdrop-filter: blur(10rpx);
  cursor: pointer;
}

.summary-card:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.summary-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.summary-arrow {
  font-size: 24rpx;
  color: #666;
  transition: transform 0.3s;
}

.summary-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  white-space: pre-line;
}

.zodiac-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 30rpx;
}

.zodiac-item {
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  position: relative;
  transition: all 0.3s;
  backdrop-filter: blur(10rpx);
}

.zodiac-item:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.zodiac-emoji {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.zodiac-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.luck-tag {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 600;
}

.luck-tag.good {
  background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
  color: #fff;
}

.luck-tag.bad {
  background: linear-gradient(135deg, #f44336 0%, #da190b 100%);
  color: #fff;
}

.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255,255,255,0.95);
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.1);
  backdrop-filter: blur(10rpx);
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.nav-text {
  font-size: 22rpx;
  color: #666;
}

.summary-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 85%;
  max-height: 80vh;
  overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.3);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
}

.modal-body {
  padding: 30rpx;
  max-height: 50vh;
  overflow-y: auto;
}

.modal-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-line;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  padding: 30rpx;
  border: none;
  font-size: 28rpx;
  font-weight: 500;
  background: #f5f5f5;
  color: #333;
}

.modal-btn.share {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.modal-btn:first-child {
  border-right: 1rpx solid #eee;
}