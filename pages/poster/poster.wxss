.custom-topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 1000;
}

.topbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  padding: 0 30rpx;
}

.topbar-left {
  width: 80rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #fff;
  font-weight: bold;
}

.topbar-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.topbar-right {
  width: 80rpx;
}

.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
  padding: 130rpx 30rpx 30rpx;
  box-sizing: border-box;
}

.poster-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.poster-image {
  width: 100%;
  max-height: 70vh;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.loading-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #f0f0f0;
  border-top-color: #ff6b6b;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 30rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #888;
}

.tips {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 0;
}

.tips-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #aaa;
}

.action-bar {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
  background: #fff;
  color: #666;
}

.action-btn.back {
  flex: 0.6;
}

.action-btn.regenerate {
  flex: 1;
}

.action-hover {
  opacity: 0.8;
  transform: scale(0.98);
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.share-bar {
  display: flex;
  gap: 20rpx;
}

.share-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  border-radius: 20rpx;
  background: #fff;
}

.share-btn.save {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e8e 100%);
  color: #fff;
}

.share-btn.friend {
  background: #07c160;
  color: #fff;
}

.share-btn.timeline {
  background: #ff9500;
  color: #fff;
}

.btn-text {
  font-size: 24rpx;
  margin-top: 8rpx;
}